generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String             @id @default(uuid())
  name             String
  email            String             @unique
  password         String
  phone            String?
  schoolName       String?
  plan             String             @default("free")
  planExpiry       DateTime?
  createdAt        DateTime           @default(now())
  students         Student[]
  payments         Payment[]
  terms            Term[]
  unmatchedPayments UnmatchedPayment[]
  invoices         Invoice[]
  receipts         Receipt[]
}

model Student {
  id          String    @id @default(uuid())
  name        String
  adm         String    @unique
  cls         String    @default("")
  fee         Float     @default(0)
  paid        Float     @default(0)
  phone       String?
  parentName  String?
  parentPhone String?
  parentEmail String?
  daysOverdue Int       @default(0)
  termId      String?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  payments    Payment[]
}

model Payment {
  id        String   @id @default(uuid())
  amount    Float
  txnRef    String?
  method    String   @default("manual")
  termId    String?
  studentId String
  feeBreakdown  Json?   @default("[]") 
  student   Student  @relation(fields: [studentId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())  // fixed: was @now() which is invalid
}

model Term {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model UnmatchedPayment {
  id        String   @id @default(uuid())
  phone     String?
  txnRef    String?
  amount    Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Invoice {
  id           String    @id @default(cuid())
  userId       String
  studentId    String
  studentName  String
  admNo        String?
  className    String
  totalFee     Float
  paid         Float     @default(0)
  balance      Float     @default(0)
  dueDate      DateTime
  scheduledFor DateTime?
  sentAt       DateTime?
  channels     String[]
  termName     String?
  note         String?
  feeBreakdown Json      @default("[]")
  parentPhone  String?
  parentName   String?
  status       String    @default("draft")
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Receipt {
  id          String   @id @default(cuid())
  userId      String
  paymentId   String
  studentId   String
  studentName String
  admNo       String?
  className   String
  amount      Float
  method      String
  txnRef      String?
  paidAt      DateTime
  sentAt      DateTime?
  channels    String[]
  type        String   @default("manual")
  balance     Float    @default(0)
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
